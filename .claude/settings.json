{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Read", "Write", "Edit",
      "Grep", "Glob",
      "WebSearch", "WebFetch",
      "Bash(npm *)", "Bash(npx *)", "Bash(node *)",
      "Bash(git *)", "Bash(cat *)", "Bash(mkdir *)",
      "Bash(cp *)", "Bash(mv *)", "Bash(echo *)",
      "Bash(curl *)", "Bash(ls *)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(sudo *)",
      "Read(.env)",
      "Read(./secrets/**)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "file=$(echo $CLAUDE_TOOL_INPUT | jq -r '.file_path // empty'); if [ -n \"$file\" ] && [[ \"$file\" == *.ts ]]; then npx prettier --write \"$file\" 2>/dev/null; fi"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude Code finished working\" with title \"Nexus AI\"' 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
