{
  "name": "nexus-crm",
  "version": "0.1.0",
  "description": "CRM-agnostic adapter layer for the Nexus dealership automation platform",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
